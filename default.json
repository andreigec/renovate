{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":timezone(Australia/Melbourne)",
    ":dependencyDashboard",
    ":rebaseStalePrs"
  ],
  "packageRules": [
    {
      "groupName": "all",
      "matchPackagePatterns": [
        "*"
      ],
      "automerge": true
    },
    {
      "groupName": "in house",
      "matchPackagePatterns": [
        "^ag-",
        "^analytica.click"
      ],
      "matchPackageNames": [
        "eslint-config-e7npm",
        "surveyfoundry.com"
      ],
      "schedule": "before 7am"
    }
  ],
  "postUpdateOptions": [
    "pnpmDedupe"
  ],
  "prConcurrentLimit": 1,
  "prNotPendingHours": 1,
  "minimumReleaseAge": "3 days",
  "semanticCommitType": "deps",
  "schedule": "before 7am on monday and thursday",
  "platformAutomerge": true,
  "automergeType": "pr",
  "rangeStrategy": "pin",
  "assignees": [
    "andreigec"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": "before 7am on sunday"
  }
}